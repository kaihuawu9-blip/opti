# 与根目录 .env.example 保持同步；完整键名以 .env.example 为准（复制为 .env.local 后填写）。
# 镜售 Opti-AI — 公网域名（示例：解析至 114.55.227.24）
# NEXT_PUBLIC_* 会打入前端包，勿写密钥。

# 鉴权：生产环境始终要求登录。仅 **本地开发** 且将下一行显式设为 false/0/off/no 时才会免登录（须重新 build）
# 缺省或 true 时走正常登录。勿在生产环境依赖「免登录」。
# NEXT_PUBLIC_ENABLE_AUTH=true
# NEXT_PUBLIC_ENABLE_AUTH=false

# 对外 API 根（优先于 OPTI_AI_API_ORIGIN；AI 聊天、支付回调回退等均会读此变量）
# 生产环境须与浏览器实际访问主域一致（含 www/apex），且须能访问到 Next 的 /api/*（不要指到纯静态站，否则会 HTML 404）。
NEXT_PUBLIC_API_URL=https://opti-ai.cn

# 主站、API 根（无末尾斜杠；未设 NEXT_PUBLIC_API_URL 时用于拼接 API 地址）
NEXT_PUBLIC_OPTI_AI_SITE_ORIGIN=https://opti-ai.cn
NEXT_PUBLIC_OPTI_AI_API_ORIGIN=https://api.opti-ai.cn

# 云端 REST（PostgREST 兼容网关，阿里云侧）
# 浏览器发起带 select= 的 PostgREST 请求时 **必须** 配置 NEXT_PUBLIC_ALIYUN_REST_URL（勿填 Next 页面根域名，应填能访问 /rest/v1 的网关根）。
# ALIYUN_REST_URL=https://api.opti-ai.cn
# ALIYUN_REST_ANON_KEY=（仅服务端或构建机可见；浏览器需 NEXT_PUBLIC_ALIYUN_REST_ANON_KEY 时务必评估泄露风险）
# NEXT_PUBLIC_ALIYUN_REST_URL=https://api.opti-ai.cn
# NEXT_PUBLIC_ALIYUN_REST_ANON_KEY=

# 可选：显式指定 AI 聊天 HTTP 接口（不设则使用 NEXT_PUBLIC_OPTI_AI_API_ORIGIN + /api/ai/chat）
# NEXT_PUBLIC_AI_CHAT_API_URL=https://api.opti-ai.cn/api/ai/chat

# 支付回调公网前缀（不设则回退 NEXT_PUBLIC_OPTI_AI_API_ORIGIN）
# PAY_NOTIFY_PUBLIC_BASE_URL=https://api.opti-ai.cn

# 直连 PostgreSQL（本地脚本 / psql；在 .env.local 填写，勿提交仓库）
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# 实验：无 PostgreSQL 时，库存/套餐商品写入项目内 data/dev-inventory.json（与 Prisma 二选一）
# 设为 1 后请注释或删除上面的 DATABASE_URL，并重启 npm run dev
# USE_LOCAL_INVENTORY_FILE=1
# 可选：自定义 JSON 路径（相对项目根或绝对路径）
# LOCAL_INVENTORY_FILE_PATH=data/dev-inventory.json

# 桌面端更新清单（不设则请求 NEXT_PUBLIC_OPTI_AI_SITE_ORIGIN/update-manifest.json；设为 off 关闭）
# NEXT_PUBLIC_UPDATE_MANIFEST_URL=off

# ===== AI 服务适配器（OpenAI 协议兼容）=====
# 服务提供商标识（仅用于配置分流与日志，不影响业务调用代码）
AI_PROVIDER=doubao

# OpenAI 兼容基址：与下述 Key 成对配置；未设时 `OPENAI_BASE_URL` 优先于 `AI_BASE_URL`（与代码一致）
# OPENAI_BASE_URL=
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 统一 API Key：服务端优先 `OPENAI_API_KEY`，未设置时回退 `AI_API_KEY`（勿提交真实密钥）
# OPENAI_API_KEY=
# AI_API_KEY=

# 模型分层：文本抽取 / 视觉识别 / 语音转写（按供应商文档填写 id）
# AI_CHAT_MODEL=
# AI_VISION_MODEL=
AI_SPEECH_MODEL=whisper-1
