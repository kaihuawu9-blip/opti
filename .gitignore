# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Electron 静态导出临时目录（见 scripts/obfuscate.js）
.electron-export-stash/

# production
/build

# misc
.DS_Store
*.pem

# 本地实验用库存 JSON（USE_LOCAL_INVENTORY_FILE=1）
/data/dev-inventory.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 本地机密（勿提交）— 环境模板请用仓库内 .env.example / env.opti-ai.example
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
