.order-page {
  background: #f4f6fa;
}

.content-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
  color: #1f2937;
  font-size: 26rpx;
}

.row:last-child {
  border-bottom: none;
}

.eye-box {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.eye-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.frame-image {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #e5e7eb;
}

.muted {
  color: #6b7280;
}

.error-card {
  border: 1rpx solid #fecaca;
  background: #fff1f2;
}
