.report-page {
  min-height: 100vh;
  padding: 24rpx;
  background: radial-gradient(circle at 20% 0%, #1e3a8a 0%, #0b1220 45%, #060b16 100%);
  box-sizing: border-box;
}

.hero-card,
.eye-card,
.ai-card {
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(56, 189, 248, 0.32);
  box-shadow: 0 8rpx 24rpx rgba(2, 132, 199, 0.2);
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #e0f2fe;
}

.hero-subtitle,
.hero-meta {
  margin-top: 8rpx;
  color: #bae6fd;
  font-size: 24rpx;
}

.eye-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.eye-title,
.section-title {
  color: #dbeafe;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.metric-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.22);
  color: #f8fafc;
  font-size: 26rpx;
}

.metric-row:last-child {
  border-bottom: none;
}

.ai-note {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(14, 116, 144, 0.2);
  color: #e0f2fe;
  font-size: 24rpx;
  line-height: 1.6;
}

.action-area {
  margin-top: 24rpx;
}

.consult-btn {
  background: linear-gradient(90deg, #0284c7 0%, #2563eb 100%);
  border: none;
}

.action-hint {
  margin-top: 12rpx;
  text-align: center;
  color: #93c5fd;
  font-size: 22rpx;
}
