.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f7f8fa;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6b7280;
}
