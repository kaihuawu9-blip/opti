# 部署 / 新环境时：复制为 `.env.local` 后填写占位符；勿将含真实机密的文件提交 Git。
# `NEXT_PUBLIC_*` 会进入浏览器端构建产物，**不得**放服务端密钥；敏感项仅放非 NEXT_PUBLIC_ 名。

# ========= 开发鉴权（仅 NODE_ENV=development 生效；免登录需显式 false/0/off/no）=========
# 已弃用名：NEXT_PUBLIC_DISABLE_AUTH（请仅使用本项）
NEXT_PUBLIC_ENABLE_AUTH=

# ========= PostgreSQL =========
DATABASE_URL=

# 无远程库时可用本地 JSON 库存（与 Prisma 二选一看业务）
USE_LOCAL_INVENTORY_FILE=
LOCAL_INVENTORY_FILE_PATH=

# ========= 公网与站点 =========
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_OPTI_AI_SITE_ORIGIN=
NEXT_PUBLIC_OPTI_AI_API_ORIGIN=

# ========= PostgREST / 云网关 =========
ALIYUN_REST_URL=
ALIYUN_REST_ANON_KEY=
ALIYUN_REST_SERVICE_KEY=
NEXT_PUBLIC_ALIYUN_REST_URL=
NEXT_PUBLIC_ALIYUN_REST_ANON_KEY=
NEXT_PUBLIC_FORCE_CLOUD_REST_CONFIGURED=

# ========= 小程序 / 会话 =========
MINIPROGRAM_CHAT_TOKEN=
MINIPROGRAM_JWT_SECRET=
NEXT_PUBLIC_MINIPROGRAM_CHAT_TOKEN=

# ========= 微信 / 小程序 app =========
WXP_APP_ID=
WXP_APP_SECRET=
WXP_LOGIN_URL=
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# 可选首启管理员：LOCAL_AUTH_BOOTSTRAP_* 为旧名，优先用下列名（勿提交到仓库）
LOCAL_AUTH_ADMIN_EMAIL=
LOCAL_AUTH_ADMIN_PASSWORD=

# ========= 阿里云 OSS =========
NEXT_PUBLIC_OSS_BUCKET=
NEXT_PUBLIC_OSS_ENDPOINT=
NEXT_PUBLIC_OSS_REGION=
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ========= OpenAI 兼容 / 豆包等 =========
AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_CHAT_MODEL=
AI_VISION_MODEL=
AI_VISION_MODEL_LITE=
AI_SPEECH_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_MODEL_VISION=
OPENAI_MODEL_PRO=

# Ark / 直连接口（与 AI_* 二选一，按你方供应商）
ARK_API_KEY=
ARK_BASE_URL=
ARK_MODEL=
DOUBAO_MODEL_ID=
DOUBAO_PRO_MODEL=

# Deepseek / 通义等（如启用对应 provider）
DEEPSEEK_API_KEY=
DEEPSEEK_OPENAI_BASE_URL=
DEEPSEEK_VL_MODEL=
QWEN_API_KEY=
QWEN_OPENAI_BASE_URL=
QWEN_VL_MODEL=

# 前端直连 AI 演示（如需要；勿填生产密钥到 NEXT_PUBLIC_）
NEXT_PUBLIC_OPENAI_API_KEY=
NEXT_PUBLIC_AI_API_KEY=
NEXT_PUBLIC_OPENAI_BASE_URL=
NEXT_PUBLIC_AI_BASE_URL=
NEXT_PUBLIC_OPENAI_MODEL=

# ========= 腾讯混元 3D / 通用腾讯 =========
TENCENT_API_KEY=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=
TENCENT_AI3D_OPENAPI_BASE=
TENCENT_AI3D_OPENAPI_SUBMIT_URL=
TENCENT_AI3D_OPENAPI_QUERY_URL=
TENCENT_AI3D_OPENAPI_MODEL=
TENCENT_AI3D_CREATE_ACTION=
TENCENT_AI3D_QUERY_ACTION=
TENCENT_AI3D_MODEL_VERSION=
TENCENT_3D_OSS_PRESIGN_EXPIRES_SEC=

# ========= 其它服务 =========
# 本地 PaddleOCR 容器基址（默认 http://127.0.0.1:8866；见 docker/ocr）
PADDLE_OCR_BASE_URL=
# 可选：浏览器直连 Paddle 的完整基址。不配时 ocr-client 会用「当前页面 hostname + :8866」
#（避免平板用局域网 IP 打开收银却仍请求 127.0.0.1 导致极慢/失败）。
NEXT_PUBLIC_PADDLE_OCR_URL=
VISION_PROVIDER=
HUNYUAN3D_MAX_CONCURRENT_CREATE=
POLL_INTERVAL=
POLL_INTERVAL_SLOW=
POLL_TIER_AFTER_MS=
MAX_POLL_ATTEMPTS=
